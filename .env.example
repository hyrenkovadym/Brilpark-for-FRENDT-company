MAIL_TO=o.sharchuk@brilpark.com
MAIL_FROM="BRIL Website <no-reply@brilpark.com>"

# Option A (recommended): SMTP with auth
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-smtp-user@example.com
MAIL_PASS=your-smtp-password

# Option B (no SMTP password): local sendmail relay on hosting
# Leave MAIL_HOST/MAIL_PORT/MAIL_USER/MAIL_PASS empty
# SENDMAIL_PATH=/usr/sbin/sendmail
